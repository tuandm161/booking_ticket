rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function onlyChanged(keys) { return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys); }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(uid) && onlyChanged(['displayName', 'fcmTokens', 'updatedAt']) && request.resource.data.role == resource.data.role && request.resource.data.email == resource.data.email && request.resource.data.fcmTokens is list && (!resource.data.keys().hasAny(['fcmTokens']) || request.resource.data.fcmTokens.hasAll(resource.data.fcmTokens)));
      allow delete: if isAdmin();
    }
    match /cinemas/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /movies/{id} { allow read: if isSignedIn(); allow create, delete: if isAdmin(); allow update: if isAdmin() || (isSignedIn() && onlyChanged(['bookingCount', 'updatedAt']) && request.resource.data.bookingCount >= resource.data.bookingCount); }
    match /rooms/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /products/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /combos/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    match /vouchers/{id} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && onlyChanged(['usedCount', 'updatedAt']) && request.resource.data.usedCount == resource.data.usedCount + 1);
    }

    match /showtimes/{id} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && onlyChanged(['heldSeats', 'bookedSeatCodes', 'updatedAt']) && request.resource.data.movieId == resource.data.movieId && request.resource.data.roomId == resource.data.roomId && request.resource.data.startTime == resource.data.startTime && request.resource.data.endTime == resource.data.endTime && request.resource.data.basePrice == resource.data.basePrice);
    }

    match /bookings/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.paymentStatus == 'paid' && request.resource.data.bookingStatus == 'confirmed';
      allow update, delete: if false;
    }
    match /notifications/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && onlyChanged(['isRead']));
      allow delete: if isAdmin();
    }
    match /{document=**} { allow read, write: if false; }
  }
}
